{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "rules": {
    "files": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "unlisted": "warn",
    "unresolved": "warn",
    "exports": "warn",
    "types": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  },
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "scripts/**/*.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.ts"
  ],
  "next": true,
  "typescript": true,
  "biome": true,
  "eslint": false,
  "drizzle": false,
  "ignoreExportsUsedInFile": true
}
