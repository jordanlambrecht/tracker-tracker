# --------------------------------------------------------------------------
# Tracker Tracker — Environment Variables
# --------------------------------------------------------------------------
# Copy this file to .env and fill in the values before running:
#   docker compose up -d
# --------------------------------------------------------------------------

# PostgreSQL connection string.
# If using the bundled db service from docker-compose.yml, match the
# hostname to the service name (default: "db"), and use the same password
# as POSTGRES_PASSWORD below.
DATABASE_URL=postgresql://postgres:change-me@db:5432/tracker_tracker

# PostgreSQL password (used by the db container in docker-compose.yml).
# Must match the password in DATABASE_URL above.
POSTGRES_PASSWORD=change-me

# AES-256 key for encrypting session cookies. Must be at least 32 characters.
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=change-this-to-a-random-string-minimum-32-chars

# Timezone for log timestamps and scheduled tasks (default: UTC)
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=America/Chicago

# Port the app is exposed on (default: 3000)
# PORT=3000

# Log level: error | warn | info | debug (default: info)
# LOG_LEVEL=info

# Log file path (optional — logs always go to stdout for docker logs)
# LOG_FILE=/data/logs/tracker-tracker.log
